{
  "git.openRepositoryInParentFolders": "never",
  "git.autoRepositoryDetection": false,
  "git.detectSubmodules": false,
  "git.detectSubmodulesLimit": 0,
  "git.repositoryScanMaxDepth": 1,
  "git.repositoryScanIgnoredFolders": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "tmp",
    "vendor",
    ".cache",
    "mnt",
    ".next",
    "mounts",
    "Volumes"
  ]
}
